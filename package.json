{
  "name": "ufo-delivery",
  "version": "1.0.0",
  "private": true,
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "seed": "node prisma/seed.js",
    "postinstall": "prisma generate",
    "db:push:prod": "dotenv -e .env.vercel.production.local -- prisma db push",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:prod": "dotenv -e .env.vercel.production.local -- prisma migrate deploy",
    "db:apply-campaign-sql": "dotenv -e .env.vercel.production.local -- prisma db execute --file prisma/migrations/20260502120000_add_campaign_tables/migration.sql --schema prisma/schema.prisma",
    "db:migrate:mark-campaign-applied": "dotenv -e .env.vercel.production.local -- prisma migrate resolve --applied 20260502120000_add_campaign_tables",
    "db:migrate:recover-campaign-failed": "dotenv -e .env.vercel.production.local -- prisma migrate resolve --rolled-back 20260502120000_add_campaign_tables && dotenv -e .env.vercel.production.local -- prisma migrate deploy",
    "db:fix-subscription-columns": "prisma db execute --file ./prisma/fix-subscription-columns.sql"
  },
  "dependencies": {
    "@alloc/quick-lru": "^5.2.0",
    "@hookform/resolvers": "^3.3.2",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "@turf/boolean-point-in-polygon": "^7.3.5",
    "@turf/helpers": "^7.3.5",
    "@vercel/blob": "^2.3.3",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.0.0",
    "d3-geo": "^3.1.1",
    "date-fns": "^3.0.0",
    "form-data": "^4.0.5",
    "leaflet": "^1.9.4",
    "next": "^14.2.35",
    "next-auth": "^4.24.0",
    "react": "^18.2.0",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.48.2",
    "react-hot-toast": "^2.4.1",
    "react-leaflet": "^4.2.1",
    "stripe": "^14.7.0",
    "tailwind-merge": "^2.2.0",
    "zod": "^3.22.4",
    "zustand": "^4.5.7"
  },
  "overrides": {
    "sucrase": "3.34.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/d3-geo": "^3.1.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20.10.0",
    "@types/react": "18.2.45",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.4.23",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.55.0",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.5.6",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.3"
  }
}
